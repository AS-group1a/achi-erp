{$SITE_ADDRESS} {
	encode gzip

	# --- ACHI theme override (tier 3) -------------------------------------
	# Serve our stylesheet, then rewrite </head> so it loads AFTER upstream's own
	# CSS and wins on cascade. No upstream file is modified — OCE_VERSION still
	# upgrades cleanly. See overrides/README.md.
	handle /achi-theme.css {
		root * /srv/overrides
		file_server
	}

	# Sidebar "Call Log" entry (tier 3, no fork). Serves the injector and rewrites
	# </head> to load it. See modules/README.md ("it is not in their sidebar").
	handle /achi-nav.js {
		root * /srv/overrides
		file_server
	}

	# Upstream precaches index.html before our response rewrite. Serve a small
	# pass-through worker that clears that stale shell and keeps navigation online.
	handle /sw.js {
		header Cache-Control "no-store, max-age=0"
		header Service-Worker-Allowed "/"
		root * /srv/overrides
		rewrite * /achi-sw.js
		file_server
	}

	# One-time escape hatch for browsers still controlled by upstream's cached
	# navigation fallback. /api is explicitly excluded by that service worker.
	handle /api/achi-browser-reset {
		header Clear-Site-Data `"cache", "storage"`
		header Cache-Control "no-store, max-age=0"
		root * /srv/overrides
		rewrite * /browser-reset.html
		file_server
	}

	replace {
		"</head>" `<link rel="stylesheet" href="/achi-theme.css?v=4"><script src="/achi-nav.js?v=44" defer></script></head>`
	}

	# Upstream documents three hard proxy requirements (deploy/docker/README.md):
	#   1. body limit >= 2GB — large CAD/PDF/point-cloud uploads
	#   2. .mjs served as JavaScript — else the pdf.js worker never loads and the
	#      take-off viewer renders BLANK
	#   3. WebSocket upgrade for /api/v1/notifications/ws and collaboration presence
	# Caddy does (2) and (3) natively; (1) is unlimited unless capped.
	request_body {
		max_size 2GB
	}

	reverse_proxy app:8080 {
		flush_interval -1     # don't buffer SSE (pack full-install streams progress)
	}
}
