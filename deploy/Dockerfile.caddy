# Caddy + replace-response, so we can inject the ACHI stylesheet into <head>
# without touching an upstream file. Stock caddy:2-alpine has no sub_filter
# equivalent; this is the supported way to add one.
FROM caddy:2-builder-alpine AS builder
RUN xcaddy build --with github.com/caddyserver/replace-response

FROM caddy:2-alpine
COPY --from=builder /usr/bin/caddy /usr/bin/caddy
